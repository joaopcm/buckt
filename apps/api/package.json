{
  "name": "@buckt/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx infisical run --domain=https://infisical.buckt.dev --env=dev -- tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "trigger:dev": "npx infisical run --domain=https://infisical.buckt.dev --env=dev -- npx trigger.dev@latest dev"
  },
  "dependencies": {
    "@aws-sdk/client-acm": "^3.1023.0",
    "@aws-sdk/client-cloudfront": "^3.1023.0",
    "@aws-sdk/client-cloudwatch": "^3.1023.0",
    "@aws-sdk/client-s3": "^3.1023.0",
    "@buckt/db": "workspace:*",
    "@buckt/shared": "workspace:*",
    "@hono/node-server": "^1",
    "@infisical/sdk": "^5.0.0",
    "@sentry/node": "^10.47.0",
    "@t3-oss/env-core": "^0.13.11",
    "@trigger.dev/sdk": "^4.4.3",
    "drizzle-orm": "^0.45.2",
    "evlog": "^2.10.0",
    "hono": "^4",
    "ioredis": "^5.10.1",
    "sharp": "^0.34.5",
    "stripe": "^20.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@trigger.dev/build": "^4.4.3",
    "@types/sharp": "^0.32.0",
    "trigger.dev": "^4.4.3",
    "tsup": "^8.5.1",
    "tsx": "^4",
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
